# Contact form → Gmail (server route: server/api/contact.post.ts)
# Create a Google App Password (requires 2-Step Verification on the account):
# https://myaccount.google.com/apppasswords
# Set these locally here, and in Vercel → Project Settings → Environment Variables.
GMAIL_USER=delf.boston@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
# Where contact messages are delivered (defaults to GMAIL_USER's inbox target).
CONTACT_TO=delf.boston@gmail.com
